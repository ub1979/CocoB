{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "enabled": true,
      "description": "Browser automation (headless)",
      "command": "npx",
      "args": ["-y", "@playwright/mcp", "--headless"],
      "env": {}
    },

    "google-workspace": {
      "type": "stdio",
      "enabled": false,
      "description": "Gmail + Calendar + Contacts (FREE, self-hosted, requires Google Cloud OAuth setup)",
      "command": "npx",
      "args": ["-y", "mcp-google"],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "~/.mcp/google-workspace/.gauth.json"
      },
      "_setup": "See EMAIL_CALENDAR_SETUP.md for Google Cloud OAuth setup instructions"
    },

    "gmail-composio": {
      "type": "stdio",
      "enabled": false,
      "description": "Gmail via Composio (easy setup, 100 free actions/month)",
      "command": "npx",
      "args": ["-y", "@composio/mcp@latest", "start", "--app", "gmail"],
      "env": {
        "COMPOSIO_API_KEY": ""
      },
      "_setup": "Run: npx @composio/cli auth login && npx @composio/cli add gmail"
    },

    "calendar-composio": {
      "type": "stdio",
      "enabled": false,
      "description": "Google Calendar via Composio (easy setup, 100 free actions/month)",
      "command": "npx",
      "args": ["-y", "@composio/mcp@latest", "start", "--app", "googlecalendar"],
      "env": {
        "COMPOSIO_API_KEY": ""
      },
      "_setup": "Run: npx @composio/cli auth login && npx @composio/cli add googlecalendar"
    }
  },

  "_comment": "Email/Calendar: Use 'google-workspace' (free, self-hosted) OR 'gmail-composio'+'calendar-composio' (easy, 100 free actions/month). See EMAIL_CALENDAR_SETUP.md",

  "_examples": {
    "outlook": {
      "type": "stdio",
      "enabled": false,
      "description": "Microsoft Outlook email (requires Composio setup)",
      "command": "npx",
      "args": ["-y", "@composio/mcp@latest", "start", "--app", "outlook"],
      "env": {
        "COMPOSIO_API_KEY": ""
      },
      "_setup": "Run: npx @composio/cli auth login && npx @composio/cli add outlook"
    },

    "outlook-calendar": {
      "type": "stdio",
      "enabled": false,
      "description": "Microsoft Outlook Calendar (requires Composio setup)",
      "command": "npx",
      "args": ["-y", "@composio/mcp@latest", "start", "--app", "outlookcalendar"],
      "env": {
        "COMPOSIO_API_KEY": ""
      },
      "_setup": "Run: npx @composio/cli auth login && npx @composio/cli add outlookcalendar"
    },

    "filesystem": {
      "type": "stdio",
      "enabled": true,
      "description": "File system access tools",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-filesystem", "/path/to/allow"],
      "env": {}
    },

    "github": {
      "type": "stdio",
      "enabled": true,
      "description": "GitHub API tools",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-github"],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your_token_here"
      }
    },

    "postgres": {
      "type": "stdio",
      "enabled": true,
      "description": "PostgreSQL database tools",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-postgres", "postgresql://localhost/mydb"],
      "env": {}
    },

    "puppeteer": {
      "type": "stdio",
      "enabled": true,
      "description": "Browser automation with Puppeteer",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-puppeteer"],
      "env": {}
    },

    "brave-search": {
      "type": "stdio",
      "enabled": true,
      "description": "Web search via Brave API",
      "command": "npx",
      "args": ["-y", "@modelcontextprotocol/server-brave-search"],
      "env": {
        "BRAVE_API_KEY": "your_api_key_here"
      }
    },

    "docker-example": {
      "type": "docker",
      "enabled": false,
      "description": "Example Docker MCP server",
      "command": "docker",
      "args": ["run", "-i", "--rm", "mcp-server-image"],
      "env": {}
    },

    "remote-sse-example": {
      "type": "sse",
      "enabled": false,
      "description": "Example remote SSE server",
      "url": "https://api.example.com/mcp/sse",
      "headers": {
        "Authorization": "Bearer your_token_here"
      }
    },

    "remote-http-example": {
      "type": "http",
      "enabled": false,
      "description": "Example remote HTTP server",
      "url": "https://api.example.com/mcp",
      "headers": {
        "Authorization": "Bearer your_token_here"
      }
    }
  }
}
