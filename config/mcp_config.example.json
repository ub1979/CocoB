{
  "mcpServers": {
    "playwright": {
      "type": "stdio",
      "enabled": true,
      "description": "Browser automation (headless)",
      "command": "npx",
      "args": [
        "-y",
        "@playwright/mcp",
        "--headless"
      ],
      "env": {}
    },
    "google-workspace": {
      "type": "stdio",
      "enabled": true,
      "description": "Gmail + Calendar + Contacts (FREE, self-hosted)",
      "command": "npx",
      "args": [
        "-y",
        "mcp-google"
      ],
      "env": {
        "GOOGLE_OAUTH_CREDENTIALS": "~/.mcp/google-workspace/.gauth.json"
      },
      "_setup": "See EMAIL_CALENDAR_SETUP.md for Google Cloud OAuth setup instructions"
    },
    "outlook": {
      "type": "stdio",
      "enabled": false,
      "description": "Outlook/Hotmail email + calendar via Microsoft Graph API (free with personal Microsoft account)",
      "command": "npx",
      "args": [
        "-y",
        "outlook-mcp"
      ],
      "env": {
        "MS_CLIENT_ID": "",
        "MS_CLIENT_SECRET": "",
        "MS_REDIRECT_URI": "http://localhost:3333/auth/callback",
        "MS_TENANT_ID": "common"
      },
      "_setup": "1. Register app at https://portal.azure.com \u2192 App registrations \u2192 Personal accounts. 2. Redirect URI: http://localhost:3333/auth/callback. 3. Add Graph API permissions: Mail.ReadWrite, Calendars.ReadWrite. 4. Create client secret. 5. Fill in MS_CLIENT_ID and MS_CLIENT_SECRET above. Use MS_TENANT_ID=common for personal accounts."
    },
    "notion": {
      "type": "stdio",
      "enabled": true,
      "description": "Notion pages, databases & calendar via official MCP server",
      "command": "npx",
      "args": [
        "-y",
        "@notionhq/notion-mcp-server"
      ],
      "env": {
        "OPENAPI_MCP_HEADERS": "{\"Authorization\": \"Bearer YOUR_NOTION_API_KEY\", \"Notion-Version\": \"2022-06-28\"}"
      },
      "_setup": "1. Go to https://www.notion.so/my-integrations \u2192 Create integration. 2. Copy the Internal Integration Secret. 3. Replace YOUR_NOTION_API_KEY above. 4. In Notion, share the pages/databases you want accessible with your integration."
    },
    "composio": {
      "type": "stdio",
      "enabled": false,
      "description": "Gmail + Calendar + more via Composio (100 free actions/month). Single server for all connected Composio apps.",
      "command": "npx",
      "args": [
        "-y",
        "@composio/mcp@latest",
        "start"
      ],
      "env": {
        "COMPOSIO_API_KEY": ""
      },
      "_setup": "Run: npx @composio/cli auth login && npx @composio/cli add gmail && npx @composio/cli add googlecalendar"
    }
  },
  "_comment": "Email/Calendar: Use 'google-workspace' (free, self-hosted) OR 'gmail-composio'+'calendar-composio' (easy, 100 free actions/month). See EMAIL_CALENDAR_SETUP.md",
  "_examples": {
    "composio-with-outlook": {
      "type": "stdio",
      "enabled": false,
      "description": "Composio with Outlook (email + calendar). Connect apps first, then start server.",
      "command": "npx",
      "args": [
        "-y",
        "@composio/mcp@latest",
        "start"
      ],
      "env": {
        "COMPOSIO_API_KEY": ""
      },
      "_setup": "Run: npx @composio/cli auth login && npx @composio/cli add outlook && npx @composio/cli add outlookcalendar"
    },
    "filesystem": {
      "type": "stdio",
      "enabled": true,
      "description": "File system access tools",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/path/to/allow"
      ],
      "env": {}
    },
    "github": {
      "type": "stdio",
      "enabled": true,
      "description": "GitHub API tools",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-github"
      ],
      "env": {
        "GITHUB_PERSONAL_ACCESS_TOKEN": "your_token_here"
      }
    },
    "postgres": {
      "type": "stdio",
      "enabled": true,
      "description": "PostgreSQL database tools",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-postgres",
        "postgresql://localhost/mydb"
      ],
      "env": {}
    },
    "puppeteer": {
      "type": "stdio",
      "enabled": true,
      "description": "Browser automation with Puppeteer",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-puppeteer"
      ],
      "env": {}
    },
    "brave-search": {
      "type": "stdio",
      "enabled": true,
      "description": "Web search via Brave API",
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-brave-search"
      ],
      "env": {
        "BRAVE_API_KEY": "your_api_key_here"
      }
    },
    "docker-example": {
      "type": "docker",
      "enabled": false,
      "description": "Example Docker MCP server",
      "command": "docker",
      "args": [
        "run",
        "-i",
        "--rm",
        "mcp-server-image"
      ],
      "env": {}
    },
    "remote-sse-example": {
      "type": "sse",
      "enabled": false,
      "description": "Example remote SSE server",
      "url": "https://api.example.com/mcp/sse",
      "headers": {
        "Authorization": "Bearer your_token_here"
      }
    },
    "remote-http-example": {
      "type": "http",
      "enabled": false,
      "description": "Example remote HTTP server",
      "url": "https://api.example.com/mcp",
      "headers": {
        "Authorization": "Bearer your_token_here"
      }
    }
  }
}